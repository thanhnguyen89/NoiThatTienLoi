<!-- Modal Forgot Password -->
<div class="modal fade" id="modalForgot" tabindex="-1" aria-labelledby="modalForgotLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-login-dialog">
    <div class="modal-content">

      <!-- Header -->
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title w-100 text-center" id="modalForgotLabel">
          <span class="d-block fs-5 fw-bold text-dark">Quên mật khẩu</span>
          <span class="d-block fs-6 fw-normal text-muted mt-1">Nhập email hoặc số điện thoại để nhận liên kết đặt lại mật khẩu.</span>
        </h5>
        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <!-- Body -->
      <div class="modal-body pt-3">
        <form class="modal-forgot-form" novalidate>

          <!-- Email / Phone -->
          <div class="form-floating mb-3">
            <input type="text" class="form-control" id="forgotEmail" placeholder="Nhập email hoặc số điện thoại">
            <label for="forgotEmail"><i class="far fa-envelope me-2 text-muted"></i>Nhập email hoặc số điện thoại</label>
          </div>

          <!-- Captcha -->
          <div class="row g-2 mb-3">
            <div class="col-5">
              <div class="form-floating">
                <input type="text" class="form-control" id="forgotCaptcha" placeholder="Mã captcha">
                <label for="forgotCaptcha">Mã captcha</label>
              </div>
            </div>
            <div class="col-7 d-flex align-items-center">
              <div class="modal-register__captcha-img flex-grow-1 text-center py-2 rounded">c q t z</div>
            </div>
          </div>

          <!-- Submit -->
          <button class="btn btn-warning w-100 py-2 fw-bold rounded-pill" type="submit" style="background:#FF6600;border-color:#FF6600;color:#fff;">
            Gửi
          </button>

          <!-- Back to login -->
          <p class="text-center mt-3 mb-0">
            <a href="#" class="text-primary small text-decoration-none" data-bs-target="#modalLogin" data-bs-toggle="modal" data-bs-dismiss="modal">
              <i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập
            </a>
          </p>
        </form>
      </div>
    </div>
  </div>
</div>
