<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập Admin | {{ siteName }}</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="../../assets/css/common.scss">
  <link rel="stylesheet" href="../../assets/css/pages/admin-login.css">
</head>
<body class="bg-login">

  <div class="login-wrapper">
    <div class="login-container">

      <!-- Logo & Title -->
      <div class="login-header text-center">
        <div class="login-logo">
          <i class="fas fa-couch"></i>
        </div>
        <h1 class="login-title">{{ siteName }}</h1>
        <p class="login-subtitle">Hệ thống quản trị</p>
      </div>

      <!-- Login Card -->
      <div class="login-card">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4 p-md-5">

            <h2 class="card-title text-center mb-1 fw-bold">Đăng nhập</h2>
            <p class="text-center text-muted mb-4 small">Vui lòng nhập thông tin để tiếp tục</p>

            <!-- Alert -->
            <div class="alert alert-danger d-none" id="loginAlert" role="alert">
              <i class="fas fa-exclamation-circle me-2"></i>
              <span id="loginAlertText">Tên đăng nhập hoặc mật khẩu không đúng.</span>
            </div>

            <form id="adminLoginForm" novalidate>

              <!-- Username -->
              <div class="form-floating mb-3">
                <input type="text" class="form-control" id="username" placeholder="Tên đăng nhập" autocomplete="username" required>
                <label for="username">
                  <i class="fas fa-user me-2 text-muted"></i>Tên đăng nhập
                </label>
                <div class="invalid-feedback">Vui lòng nhập tên đăng nhập</div>
              </div>

              <!-- Password -->
              <div class="form-floating mb-3">
                <input type="password" class="form-control" id="password" placeholder="Mật khẩu" autocomplete="current-password" required>
                <label for="password">
                  <i class="fas fa-lock me-2 text-muted"></i>Mật khẩu
                </label>
                <div class="invalid-feedback">Vui lòng nhập mật khẩu</div>
              </div>

              <!-- Remember & Forgot -->
              <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="rememberMe">
                  <label class="form-check-label small" for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>
                <a href="#" class="text-primary small text-decoration-none">Quên mật khẩu?</a>
              </div>

              <!-- Submit -->
              <button class="btn btn-success w-100 py-2 fw-bold rounded-pill shadow-sm" type="submit" id="loginBtn">
                <span id="loginBtnText">Đăng nhập</span>
                <span id="loginBtnLoader" class="spinner-border spinner-border-sm ms-2 d-none" role="status"></span>
              </button>

            </form>

            <!-- Divider -->
            <div class="d-flex align-items-center gap-3 my-4">
              <hr class="flex-grow-1 mb-0">
              <span class="text-muted small">hoặc</span>
              <hr class="flex-grow-1 mb-0">
            </div>

            <!-- Social Login -->
            <div class="d-grid gap-2">
              <button class="btn btn-outline-secondary rounded-3 py-2" type="button">
                <i class="fab fa-google me-2 text-danger"></i>Đăng nhập với Google
              </button>
            </div>

          </div>
        </div>
      </div>

      <!-- Footer -->
      <div class="login-footer text-center">
        <p class="mb-1 text-muted small">&copy; 2026 {{ siteName }}. Tất cả quyền được bảo lưu.</p>
        <p class="mb-0">
          <a href="/" class="text-primary text-decoration-none small">
            <i class="fas fa-arrow-left me-1"></i>Quay lại cửa hàng
          </a>
        </p>
      </div>

    </div>
  </div>

  <script src="../../assets/js/common.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const form = document.getElementById('adminLoginForm');
      const alertBox = document.getElementById('loginAlert');
      const loginBtn = document.getElementById('loginBtn');
      const loginBtnText = document.getElementById('loginBtnText');
      const loginBtnLoader = document.getElementById('loginBtnLoader');

      form.addEventListener('submit', function (e) {
        e.preventDefault();

        // Reset
        alertBox.classList.add('d-none');
        form.classList.remove('was-validated');

        // Validate
        const username = document.getElementById('username');
        const password = document.getElementById('password');
        let valid = true;

        if (!username.value.trim()) {
          username.classList.add('is-invalid');
          valid = false;
        } else {
          username.classList.remove('is-invalid');
        }

        if (!password.value.trim()) {
          password.classList.add('is-invalid');
          valid = false;
        } else {
          password.classList.remove('is-invalid');
        }

        if (!valid) {
          form.classList.add('was-validated');
          return;
        }

        // Simulate login
        loginBtn.disabled = true;
        loginBtnText.textContent = 'Đang đăng nhập...';
        loginBtnLoader.classList.remove('d-none');

        setTimeout(() => {
          loginBtn.disabled = false;
          loginBtnText.textContent = 'Đăng nhập';
          loginBtnLoader.classList.add('d-none');

          // Demo: show error (remove in production)
          alertBox.classList.remove('d-none');
          form.classList.add('was-validated');
        }, 1500);
      });

      // Remove invalid on input
      ['username', 'password'].forEach(id => {
        const el = document.getElementById(id);
        el.addEventListener('input', () => {
          el.classList.remove('is-invalid');
        });
      });
    });
  </script>
</body>
</html>
