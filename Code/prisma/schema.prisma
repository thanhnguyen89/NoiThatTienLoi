  customerEmail String? @db.VarChar(255)

  billingContactName  String? @db.VarChar(255)
  billingContactPhone String? @db.VarChar(50)
  billingContactEmail String? @db.VarChar(255)
  billingCountryCode  String? @db.VarChar(20)
  billingProvinceCode String? @db.VarChar(50)
  billingProvinceName String? @db.VarChar(255)
  billingDistrictCode String? @db.VarChar(50)
  billingDistrictName String? @db.VarChar(255)
  billingWardCode     String? @db.VarChar(50)
  billingWardName     String? @db.VarChar(255)
  billingAddressLine  String? @db.VarChar(500)
  billingFullAddress  String? @db.VarChar(1000)

  shippingContactName  String  @db.VarChar(255)
  shippingContactPhone String  @db.VarChar(50)
  shippingContactEmail String? @db.VarChar(255)
  shippingCountryCode  String? @db.VarChar(20)
  shippingProvinceCode String? @db.VarChar(50)
  shippingProvinceName String? @db.VarChar(255)
  shippingDistrictCode String? @db.VarChar(50)
  shippingDistrictName String? @db.VarChar(255)
  shippingWardCode     String? @db.VarChar(50)
  shippingWardName     String? @db.VarChar(255)
  shippingAddressLine  String  @db.VarChar(500)
  shippingFullAddress  String? @db.VarChar(1000)
  shippingLatitude     Float?
  shippingLongitude    Float?

  subtotalAmount   Float @default(0)
  discountAmount   Float @default(0)
  shippingAmount   Float @default(0)
  otherFeeAmount   Float @default(0)
  taxAmount        Float @default(0)
  grandTotalAmount Float @default(0)

  depositAmount   Float @default(0)
  remainingAmount Float @default(0)

  orderStatus   OrderStatus   @default(pending)
  paymentStatus PaymentStatus @default(unpaid)

  customerNote String? @db.Text
  internalNote String? @db.Text

  placedAt  DateTime? @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime?
  createdBy String?  @db.VarChar(100)
  updatedBy String?  @db.VarChar(100)
  isDeleted Boolean?  @default(false)
  deletedBy String?   @db.VarChar(100)
