  name          String?   @db.VarChar(1000)
  menuTypeId    BigInt?
  isActive      Boolean?
  createdUserId String?   @db.Uuid
  createdDate   DateTime? @db.Timestamp(6)
  lastUpdUserId String?   @db.Uuid
  lastUpdDate   DateTime? @db.Timestamp(6)
  isDeleted     Boolean?  @default(false)
  deletedUser   String?   @db.Uuid
  deletedDate   DateTime? @db.Timestamp(6)

  @@map("menu")
}

// ============================================================
// Menu Link
// ============================================================
model MenuLink {
  id            String    @id @default(cuid())
  title         String?   @db.VarChar(1000)
  slug          String?
  target        String?   @db.VarChar(1000)
  menuId        BigInt?
  icon          String?
  parentId      String?   @db.Uuid
  entityId      BigInt?
  entityName    String?   @db.VarChar(1000)
  nofollow      Boolean?
  level         Int?
  sortOrder     Int?
  createdUserId String?   @db.Uuid
  createdDate   DateTime? @db.Timestamp(6)
  lastUpdUserId String?   @db.Uuid
  lastUpdDate   DateTime? @db.Timestamp(6)
  isDeleted     Boolean?  @default(false)
  deletedUser   String?   @db.Uuid
  deletedDate   DateTime? @db.Timestamp(6)

