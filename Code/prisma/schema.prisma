}

// ============================================================
// Menu Page
// ============================================================
model Page {
  id               String    @id @default(cuid())
  pageName         String?   @db.VarChar(1000)
  title            String?   @db.VarChar(1000)
  body             String?
  sortOrder        Int?
  shortDescription String?
  image            String?   @db.VarChar(512)
  isShowHome       Boolean?  @default(true)
  isActive         Boolean?
  metaKeywords     String?   @db.VarChar(400)
  metaDescription  String?
  metaTitle        String?   @db.VarChar(400)
  createdUserId    String?   @db.Uuid
  createdDate      DateTime? @db.Timestamp(6)
  lastUpdUserId    String?   @db.Uuid
  lastUpdDate      DateTime? @db.Timestamp(6)
  isDeleted        Boolean?  @default(false)
  deletedUser      String?   @db.Uuid
  deletedDate      DateTime? @db.Timestamp(6)
  slugRedirect     String?   @db.VarChar(1000)
  isRedirect       Boolean?
  seoCanonical     String?   @db.VarChar(1000)
  seoNoindex       Boolean?
  errorCode        String?   @db.VarChar(50)

  @@index([isActive])
  @@index([isShowHome])
  @@index([slugRedirect])
  @@map("page")
}

// ============================================================
// SliderPicture
// ============================================================
model SliderPicture {
  id        String  @id @default(cuid())
  comment   String? @db.VarChar(1000)
  name      String? @db.VarChar(1000)
  image     String? @db.VarChar(4000)
  sortOrder Int?
  isActive  Boolean @default(true)

  @@map("slider_picture")
}

// ============================================================
// UrlRecord
// ============================================================
model UrlRecord {
  id            String    @id @default(cuid())
  entityId      BigInt?
  entityName    String?
  slug          String?   @db.VarChar(1000)
  isActive      Boolean?
  isDeleted     Boolean?
  deletedUserId String?   @db.Uuid
  deletedDate   DateTime?
  slugRedirect  String?   @db.VarChar(1000)
  isRedirect    Boolean?
  errorCode     String?   @db.VarChar(50)

  @@unique([slug])
  @@index([entityId, entityName])
  @@index([slugRedirect])
  @@map("url_record")
}

// ============================================================
// UrlRecord
// ============================================================
model UrlRecordReference {
  id             String   @id @default(cuid())
  entityName     String?  @db.VarChar(1000)
  controllerName String?  @db.VarChar(1000)
  actionName     String?  @db.VarChar(1000)
  isActive       Boolean?

  @@unique([entityName, controllerName, actionName])
  @@index([entityName])
  @@index([isActive])
  @@map("Url_Record_Reference")
}
