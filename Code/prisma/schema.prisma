  discountAmount    Float @default(0)
  finalShippingCost Float @default(0)

  providerOrderCode String?   @db.VarChar(100)
  trackingCode      String?   @db.VarChar(100)
  shippedAt         DateTime?
  deliveredAt       DateTime?

  note         String? @db.Text
  metadataJson Json?

 createdAt DateTime @default(now())
  updatedAt DateTime?
  createdBy String?  @db.VarChar(100)
  updatedBy String?  @db.VarChar(100)
  isDeleted Boolean?  @default(false)
  deletedBy String?   @db.VarChar(100)
  deletedAt DateTime? @db.Timestamp(6)

  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouse        Warehouse?        @relation(fields: [warehouseId], references: [id])
  shippingProvider ShippingProvider? @relation(fields: [shippingProviderId], references: [id])

  @@index([orderId])
  @@index([shippingProviderId])
  @@index([warehouseId])
  @@map("order_shipments")
}

// ============================================================
// ORDER STATUS HISTORY
// ============================================================
model OrderStatusHistory {
  id            String   @id @default(cuid())
  orderId       String
  fromStatus    String?  @db.VarChar(50)
  toStatus      String   @db.VarChar(50)
  changedByType String?  @db.VarChar(50)
  changedById   String?  @db.VarChar(100)
  note          String?  @db.Text
 createdAt DateTime @default(now())
  updatedAt DateTime?
  createdBy String?  @db.VarChar(100)
  updatedBy String?  @db.VarChar(100)
  isDeleted Boolean?  @default(false)
  deletedBy String?   @db.VarChar(100)
  deletedAt DateTime? @db.Timestamp(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_histories")
}
