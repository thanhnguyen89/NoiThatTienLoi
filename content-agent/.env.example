# ============================================
# CONTENT MARKETING AGENT — Environment Variables
# ============================================
# Hướng dẫn: cp .env.example .env
# Sau đó điền giá trị thật vào .env
# KHÔNG commit file .env lên git
# ============================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Search ---
TAVILY_API_KEY=tvly-...
# Hoặc dùng Brave Search thay thế:
# BRAVE_SEARCH_API_KEY=BSA...

# --- Image Generation ---
# Chọn 1 trong 2:
OPENAI_API_KEY=sk-...          # Cho DALL-E 3
# FAL_API_KEY=...              # Cho Flux (rẻ hơn, nhanh hơn)

# --- WordPress CMS ---
WORDPRESS_URL=https://yoursite.com
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# Tạo App Password tại: WordPress Admin → Users → Profile → Application Passwords

# --- Database (Supabase) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...    # Chỉ dùng server-side

# --- Queue (Redis) ---
REDIS_URL=redis://localhost:6379
# Production: redis://user:password@host:6379

# --- Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Để trống nếu không dùng Slack

# --- App Config ---
NODE_ENV=development           # development | staging | production
LOG_LEVEL=info                 # debug | info | warn | error
MAX_RETRIES=3
PIPELINE_TIMEOUT_MINUTES=30

# --- Content Config ---
DEFAULT_CATEGORY=Uncategorized
DEFAULT_LANGUAGE=vi
DEFAULT_MARKET=VN
HUMANNESS_THRESHOLD=76         # Bài cần đạt điểm này mới publish
AUTO_PUBLISH=false             # true = publish ngay sau khi đạt threshold
                               # false = luôn hỏi xác nhận (khuyến nghị)
